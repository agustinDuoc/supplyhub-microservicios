# Railway: mapear MYSQLHOST -> DB_HOST, MYSQLPORT -> DB_PORT, etc.
# Cloud: usar server.port=${PORT:808x} (ya configurado en application.yml)

# Root Directory por servicio en Railway:
# ms-eureka      -> ms-eureka
# ms-gateway     -> ms-gateway
# ms-auth        -> ms-auth
# ms-clientes    -> ms-clientes
# ms-proveedores -> ms-proveedores
# ms-categorias  -> ms-categorias
# ms-productos   -> ms-productos
# ms-cotizaciones -> ms-cotizaciones
# ms-inventario  -> ms-inventario
# ms-ordenes-compra -> ms-ordenes-compra
# ms-pagos       -> ms-pagos
# ms-despachos   -> ms-despachos
